# Actualizar e instalar Ansible y dependencias necesarias
sudo apt update
sudo apt install ansible sshpass -y

# Validar la instalación
ansible --version

ssh root@TUIPDIIGO
# Crear usuario (te pedirá inventar una contraseña, pon una simple por ahora)
adduser ansible

# Darle permisos de administrador (sudo)
usermod -aG sudo ansible

# Hacer que no le pida contraseña al usar sudo (vital para Ansible)
echo "ansible ALL=(ALL) NOPASSWD:ALL" | sudo tee /etc/sudoers.d/ansible

# Salir de DigitalOcean para volver a tu Mint
exit
ssh-copy-id ansible@TUIPDIGIO
