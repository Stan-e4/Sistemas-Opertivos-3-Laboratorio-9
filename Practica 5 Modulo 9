---
- name: Playbook Examen Final Linux
  hosts: linux
  become: yes
  tasks:
    - name: 1. Actualizar repositorios (apt update)
      apt:
        update_cache: yes

    - name: 2. Crear usuario adrian123 y agregarlo a sudoers
      user:
        name: adrian123
        groups: sudo
        append: yes
        shell: /bin/bash

    - name: 3. Instalar bashtop
